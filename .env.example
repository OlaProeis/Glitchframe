# Glitchframe (optional path overrides)
# GLITCHFRAME_CACHE_DIR=
# GLITCHFRAME_OUTPUTS_DIR=
# Optional encoder override (e.g. libx264 on CI without NVENC); default is h264_nvenc
# GLITCHFRAME_FFMPEG_VIDEO_CODEC=libx264
# Optional extra ffmpeg video args (space-separated) when not using h264_nvenc defaults
# GLITCHFRAME_FFMPEG_VIDEO_ARGS=-preset ultrafast -crf 28
# MP4 color metadata for browser-accurate playback (gr.Video / Chrome). Set "off" to skip, or set custom space-separated args:
# GLITCHFRAME_FFMPEG_COLOR_METADATA=off
# GLITCHFRAME_FFMPEG_COLOR_METADATA_ARGS=-pix_fmt:v yuv420p -color_primaries:v bt709
# GLITCHFRAME_PRESETS_DIR=
# GLITCHFRAME_MODEL_CACHE=
# Optional: full paths to ffmpeg/ffprobe if not on PATH
# GLITCHFRAME_FFMPEG=
# GLITCHFRAME_FFPROBE=
# Align lyrics (WhisperX): optional. ``silero`` avoids Pyannote+cuDNN DLL issues on some Windows setups.
# Pinokio sets this via start.js; for local runs, leave unset (WhisperX default) unless you need it.
# GLITCHFRAME_WHISPERX_VAD_METHOD=silero
# WhisperX device: Pinokio ``start.js`` defaults to ``cpu`` so Align lyrics avoids Windows CTranslate2/cuDNN GPU issues; omit or set cuda for GPU alignment.
# GLITCHFRAME_WHISPERX_DEVICE=cpu

# HiDream-O1-Image backend (optional alternative to SDXL for AI background stills).
# When set, the Background keyframes tab's "Image generator" radio can switch from
# SDXL to HiDream — Glitchframe spawns ``pipeline/background_stills_hidream_worker.py``
# in the HiDream venv via subprocess, so HiDream's flash-attn / heavy CUDA stack
# never collides with the main app environment.
# Pinokio users typically point GLITCHFRAME_HIDREAM_PYTHON at the Pinokio app's
# venv python.exe and GLITCHFRAME_HIDREAM_REPO at the cloned HiDream-O1-Image folder.
# GLITCHFRAME_HIDREAM_PYTHON=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image\env\Scripts\python.exe
# GLITCHFRAME_HIDREAM_REPO=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image
# GLITCHFRAME_HIDREAM_MODEL_PATH=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image\models\hidream-o1-image-dev-fp8
# Inference recipe: dev (28 steps, ~16 GB on FP8) or full (50 steps, more VRAM).
# GLITCHFRAME_HIDREAM_MODEL_TYPE=dev
# Optional generation resolution override (defaults: 1280x720 then Lanczos-upscaled to render size).
# GLITCHFRAME_HIDREAM_GEN_WIDTH=1280
# GLITCHFRAME_HIDREAM_GEN_HEIGHT=720
# Optional pipeline class import override if your fork renames the entry point.
# GLITCHFRAME_HIDREAM_PIPELINE_IMPORT=models.pipeline:HiDreamImagePipeline

# Legacy names (still read if set): MUSICVIDS_CACHE_DIR, MUSICVIDS_OUTPUTS_DIR, etc.
