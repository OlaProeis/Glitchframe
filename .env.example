# Glitchframe (optional path overrides)
# GLITCHFRAME_CACHE_DIR=
# GLITCHFRAME_OUTPUTS_DIR=
# Optional encoder override (e.g. libx264 on CI without NVENC); default is h264_nvenc
# GLITCHFRAME_FFMPEG_VIDEO_CODEC=libx264
# Optional extra ffmpeg video args (space-separated) when not using h264_nvenc defaults
# GLITCHFRAME_FFMPEG_VIDEO_ARGS=-preset ultrafast -crf 28
# GLITCHFRAME_PRESETS_DIR=
# GLITCHFRAME_MODEL_CACHE=
# Optional: full paths to ffmpeg/ffprobe if not on PATH
# GLITCHFRAME_FFMPEG=
# GLITCHFRAME_FFPROBE=
# Align lyrics (WhisperX): optional. ``silero`` avoids Pyannote+cuDNN DLL issues on some Windows setups.
# Pinokio sets this via start.js; for local runs, leave unset (WhisperX default) unless you need it.
# GLITCHFRAME_WHISPERX_VAD_METHOD=silero

# Legacy names (still read if set): MUSICVIDS_CACHE_DIR, MUSICVIDS_OUTPUTS_DIR, etc.
