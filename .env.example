# Glitchframe (optional path overrides)
# GLITCHFRAME_CACHE_DIR=
# GLITCHFRAME_OUTPUTS_DIR=
# Optional encoder override (e.g. libx264 on CI without NVENC); default is h264_nvenc
# GLITCHFRAME_FFMPEG_VIDEO_CODEC=libx264
# Optional extra ffmpeg video args (space-separated) when not using h264_nvenc defaults
# GLITCHFRAME_FFMPEG_VIDEO_ARGS=-preset ultrafast -crf 28
# MP4 color metadata for browser-accurate playback (gr.Video / Chrome). Set "off" to skip, or set custom space-separated args:
# GLITCHFRAME_FFMPEG_COLOR_METADATA=off
# GLITCHFRAME_FFMPEG_COLOR_METADATA_ARGS=-pix_fmt:v yuv420p -color_primaries:v bt709
# GLITCHFRAME_PRESETS_DIR=
# GLITCHFRAME_MODEL_CACHE=
# Optional: full paths to ffmpeg/ffprobe if not on PATH
# GLITCHFRAME_FFMPEG=
# GLITCHFRAME_FFPROBE=
# Align lyrics (WhisperX): optional. ``silero`` avoids Pyannote+cuDNN DLL issues on some Windows setups.
# Pinokio sets this via start.js; for local runs, leave unset (WhisperX default) unless you need it.
# GLITCHFRAME_WHISPERX_VAD_METHOD=silero
# WhisperX device: Pinokio ``start.js`` defaults to ``cpu`` so Align lyrics avoids Windows CTranslate2/cuDNN GPU issues; omit or set cuda for GPU alignment.
# GLITCHFRAME_WHISPERX_DEVICE=cpu

# HiDream-O1-Image backend (optional alternative to SDXL for AI background stills).
# Runs ``pipeline/background_stills_hidream_worker.py`` in a separate Python so HiDream's
# CUDA / flash-attn stack never collides with the main app.
# With no env vars: first use clones HiDream-O1-Image into GLITCHFRAME_MODEL_CACHE/hidream/
# and downloads HF weights (``dev`` → drbaph/HiDream-O1-Image-FP8 by default; the worker loads
# FP8 checkpoints as bfloat16 and dequantizes Float8 weights → bfloat16 in-place so HiDream's
# generate_image BF16 autocast path does not hit Float8 promotion errors).
# GLITCHFRAME_HIDREAM_PYTHON at a HiDream-capable interpreter (Pinokio's venv is ideal);
# if unset, Glitchframe tries <repo>/env/ then falls back to this app's python (often not enough).
# GLITCHFRAME_HIDREAM_PYTHON=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image\env\Scripts\python.exe
# GLITCHFRAME_HIDREAM_REPO=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image
# GLITCHFRAME_HIDREAM_MODEL_PATH=C:\pinokio\api\github-com-cocktailpeanut-hidream-o1\HiDream-O1-Image\models\hidream-o1-image-dev-fp8
# Optional HF repo id for auto-downloaded weights (defaults: dev → drbaph FP8, full → HiDream-ai).
# GLITCHFRAME_HIDREAM_HF_REPO_ID=drbaph/HiDream-O1-Image-FP8
# Inference recipe: dev (28 steps, ~16 GB on FP8) or full (50 steps, more VRAM).
# GLITCHFRAME_HIDREAM_MODEL_TYPE=dev
# Optional generation resolution override (defaults: 1280x720 then Lanczos-upscaled to render size).
# GLITCHFRAME_HIDREAM_GEN_WIDTH=1280
# GLITCHFRAME_HIDREAM_GEN_HEIGHT=720
# Optional: ``auto`` (default), or module:Class for a diffusers-style fork.
# GLITCHFRAME_HIDREAM_PIPELINE_IMPORT=auto

# Optional: allow libraries to use real stdout (breaks JSONL if they print). Debug only.
# GLITCHFRAME_HIDREAM_WORKER_ALLOW_LIB_STDOUT=1
# HiDream native worker: float32 vs bfloat16 for Qwen from_pretrained (default auto → bfloat16).
# Note: this only changes the dtype of *newly created* tensors. Float8 weights inside FP8 repos
# stay Float8 on disk regardless and are dequantized in-place after load (see DEQUANT_FLOAT8).
# GLITCHFRAME_HIDREAM_NATIVE_WEIGHTS_DTYPE=bfloat16
# After load, cast every Float8 parameter/buffer to bfloat16 in place so HiDream's generate_image
# BF16 autocast path is consistent (fixes "Promotion for Float8 Types is not supported" inside
# qwen3_vl_transformers' torch.where on FP8 checkpoints like drbaph/HiDream-O1-Image-FP8).
# Set to 0 only if your environment provides true FP8 ops (torchao / custom fork). Default: on.
# GLITCHFRAME_HIDREAM_DEQUANT_FLOAT8=0
# Worker logs a one-shot dtype audit (parameters/buffers per dtype, sample Float8 tensor names) right
# after Qwen3VL.from_pretrained AND after the Float8 dequant pass so you can confirm the cast worked.
# Set to 0 to skip the audit (the audit is read-only and adds no GPU work).
# GLITCHFRAME_HIDREAM_WORKER_DIAGNOSE_DTYPES=0

# Optional: set to 0 if wrapping stdout/stderr breaks your terminal (rare).
# GLITCHFRAME_HIDREAM_WORKER_UTF8_STDIO=0

# Legacy names (still read if set): MUSICVIDS_CACHE_DIR, MUSICVIDS_OUTPUTS_DIR, etc.
